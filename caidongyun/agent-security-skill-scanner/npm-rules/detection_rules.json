{
  "version": "2.0.0",
  "updated": "2026-03-12",
  "total_rules": 110,
  "categories": [
    {
      "id": "malware",
      "name": "恶意代码检测",
      "weight": 30,
      "rules": [
        {
          "id": "MALWARE-001",
          "name": "eval/exec滥用",
          "severity": "CRITICAL",
          "patterns": [
            "\\beval\\s*\\([^)]+\\)",
            "\\bexec\\s*\\([^)]+\\)",
            "\\bcompile\\s*\\([^)]+,\\s*'[^']*'\\s*,\\s*'exec'"
          ],
          " whitelist": [
            "eval\\s*\\(\\s*['\"]1\\+1['\"]",
            "eval\\s*\\(\\s*safe_expression",
            "with\\s+Sandbox\\(\\)"
          ]
        },
        {
          "id": "MALWARE-002",
          "name": "动态导入",
          "severity": "HIGH",
          "patterns": [
            "__import__\\s*\\([^)]+\\)",
            "importlib\\.import_module\\s*\\([^)]+\\)",
            "getattr\\s*\\([^)]+,\\s*['\"][^'\"]+['\"]"
          ]
        },
        {
          "id": "MALWARE-003",
          "name": "网络请求无限制",
          "severity": "HIGH",
          "patterns": [
            "requests\\.(get|post|put|delete)\\s*\\([^)]*\\)",
            "verify\\s*=\\s*False",
            "urllib\\.request\\.urlopen"
          ]
        },
        {
          "id": "MALWARE-004",
          "name": "数据窃取模式",
          "severity": "CRITICAL",
          "patterns": [
            "os\\.environ\\s*\\[['\"](.*PASSWORD|.*KEY|.*SECRET|.*TOKEN)['\"]\\]",
            "requests\\.post\\s*\\([^)]+,\\s*data\\s*=",
            "open\\s*\\(\\s*['\"]/tmp/"
          ]
        },
        {
          "id": "MALWARE-005",
          "name": "系统命令执行",
          "severity": "CRITICAL",
          "patterns": [
            "os\\.system\\s*\\([^)]+\\)",
            "subprocess\\.(call|run|Popen)\\s*\\([^)]+shell\\s*=\\s*True",
            "os\\.popen\\s*\\([^)]+\\)"
          ]
        },
        {
          "id": "MALWARE-006",
          "name": "反序列化漏洞",
          "severity": "CRITICAL",
          "patterns": [
            "pickle\\.loads\\s*\\([^)]+\\)",
            "yaml\\.load\\s*\\([^)]+Loader\\s*=\\s*None",
            "marshal\\.load"
          ]
        },
        {
          "id": "MALWARE-007",
          "name": "XPATH注入",
          "severity": "MEDIUM",
          "patterns": [
            "xpath\\.compile\\s*\\([^)]+\\).*\\.xml",
            "\\.xpath\\s*\\([^)]+\\)"
          ]
        },
        {
          "id": "MALWARE-008",
          "name": "模板注入",
          "severity": "CRITICAL",
          "patterns": [
            "Template\\s*\\([^)]+\\)\\.render",
            "render_template_string\\s*\\([^)]+\\)",
            "{{[^}]*}}"
          ]
        },
        {
          "id": "MALWARE-009",
          "name": "正则 DoS",
          "severity": "MEDIUM",
          "patterns": [
            "re\\.(compile|match|search)\\s*\\([^)]*\\*[^)]*\\+",
            "regex\\s*\\*[^)]*\\+[^)]*\\?"
          ]
        },
        {
          "id": "MALWARE-010",
          "name": "JWT算法篡改",
          "severity": "HIGH",
          "patterns": [
            "jwt\\.decode\\s*[^)]*algorithm\\s*=\\s*['\"]HS256",
            "jwt\\.encode\\s*[^)]*algorithm\\s*=\\s*None"
          ]
        },
        {
          "id": "MALWARE-011",
          "name": "不安全的随机数",
          "severity": "MEDIUM",
          "patterns": [
            "random\\.(random|randint|choice)\\s*\\(",
            "Math\\.random\\s*\\(\\)"
          ]
        },
        {
          "id": "MALWARE-012",
          "name": "调试模式开启",
          "severity": "MEDIUM",
          "patterns": [
            "DEBUG\\s*=\\s*True",
            "debug\\s*=\\s*True",
            "app\\.run\\s*\\([^)]*debug\\s*=\\s*True"
          ]
        }
      ]
    },
    {
      "id": "backdoor",
      "name": "后门模式检测",
      "weight": 25,
      "rules": [
        {
          "id": "BACKDOOR-001",
          "name": "隐藏执行(Base64编码)",
          "severity": "CRITICAL",
          "patterns": [
            "base64\\.b64decode\\s*\\([^)]+\\)",
            "eval\\s*\\(\\s*base64",
            "exec\\s*\\(\\s*base64",
            "zlib\\.decompress\\s*\\(\\s*base64"
          ]
        },
        {
          "id": "BACKDOOR-002",
          "name": "定时任务后门",
          "severity": "HIGH",
          "patterns": [
            "schedule\\.every\\s*\\([^)]+\\)",
            "cron\\.schedule",
            "@scheduled\\s*\\(",
            "setInterval",
            "setTimeout"
          ]
        },
        {
          "id": "BACKDOOR-003",
          "name": "隐藏通道",
          "severity": "CRITICAL",
          "patterns": [
            "socket\\.(connect|bind)\\s*\\(",
            " threading\\.Thread.*daemon\\s*=\\s*True",
            "subprocess\\.Popen.*stdout\\s*=\\s*subprocess\\.PIPE"
          ]
        },
        {
          "id": "BACKDOOR-004",
          "name": "反弹shell",
          "severity": "CRITICAL",
          "patterns": [
            "/bin/sh\\s*-i",
            "bash\\s*-i",
            "nc\\s+-e\\s+/bin",
            "socat\\s+exec"
          ]
        },
        {
          "id": "BACKDOOR-005",
          "name": "Webshell特征",
          "severity": "CRITICAL",
          "patterns": [
            "system\\s*\\(\\s*\\$_GET",
            "eval\\s*\\(\\s*\\$_POST",
            "base64_decode\\s*\\(\\s*\\$_"
          ]
        },
        {
          "id": "BACKDOOR-006",
          "name": "持久化机制",
          "severity": "HIGH",
          "patterns": [
            "registry\\.SetValue",
            "HKCU\\\\Software",
            "launchd\\.plist",
            "~/Library/LaunchAgents"
          ]
        },
        {
          "id": "BACKDOOR-007",
          "name": "权限维持",
          "severity": "HIGH",
          "patterns": [
            "chmod\\s+\\+\\s*x\\s+.*\\.sh",
            "crontab\\s+-r",
            "usermod\\s+-s\\s+/bin"
          ]
        },
        {
          "id": "BACKDOOR-008",
          "name": "rootkit特征",
          "severity": "CRITICAL",
          "patterns": [
            "LD_PRELOAD",
            "LD_LIBRARY_PATH",
            "/proc/self/exe"
          ]
        },
        {
          "id": "BACKDOOR-009",
          "name": "隐藏文件/目录",
          "severity": "MEDIUM",
          "patterns": [
            "\\\\.\\\\w+",
            "chattr\\s+\\+i",
            "xattr\\s*-w"
          ]
        },
        {
          "id": "BACKDOOR-010",
          "name": "可疑网络行为",
          "severity": "HIGH",
          "patterns": [
            "requests\\.get.*User-Agent.*curl",
            "socket\\.connect.*4444",
            "http://.*:\\d{4,5}/"
          ]
        }
      ]
    },
    {
      "id": "privilege",
      "name": "权限滥用检测",
      "weight": 20,
      "rules": [
        {
          "id": "PRIV-001",
          "name": "权限提升尝试",
          "severity": "HIGH",
          "patterns": [
            "sudo\\s+",
            "chmod\\s+4777",
            "chown\\s+root:root"
          ]
        },
        {
          "id": "PRIV-002",
          "name": "敏感API滥用",
          "severity": "MEDIUM",
          "patterns": [
            "ctypes\\.windll",
            "win32api\\.WinExec",
            "os\\.setuid"
          ]
        },
        {
          "id": "PRIV-003",
          "name": " Capabilities 风险",
          "severity": "HIGH",
          "patterns": [
            "CAP_NET_RAW",
            "CAP_SYS_ADMIN",
            "CAP_SYS_TIME"
          ]
        },
        {
          "id": "PRIV-004",
          "name": "容器逃逸",
          "severity": "CRITICAL",
          "patterns": [
            "docker\\.sock",
            "--privileged",
            "--net=host"
          ]
        },
        {
          "id": "PRIV-005",
          "name": "特权容器检测",
          "severity": "CRITICAL",
          "patterns": [
            "securityContext:\\s*privileged:\\s*true",
            "hostPID:\\s*true",
            "hostNetwork:\\s*true"
          ]
        },
        {
          "id": "PRIV-006",
          "name": "危险挂载",
          "severity": "HIGH",
          "patterns": [
            "volumeMounts.*/var/run/docker.sock",
            "mount.*/etc/host",
            "volume.*hostPath.*/"
          ]
        },
        {
          "id": "PRIV-007",
          "name": "绕过安全机制",
          "severity": "HIGH",
          "patterns": [
            "seccomp\\s+unconfined",
            "apparmor=unconfined",
            "no-sandbox"
          ]
        },
        {
          "id": "PRIV-008",
          "name": "敏感命令执行",
          "severity": "MEDIUM",
          "patterns": [
            "passwd\\s+",
            "shadow\\s+",
            "su\\s+-"
          ]
        },
        {
          "id": "PRIV-009",
          "name": "权限检查绕过",
          "severity": "MEDIUM",
          "patterns": [
            "is_admin\\s*=\\s*True",
            "check_permission\\s*return\\s*True",
            "//admin"
          ]
        }
      ]
    },
    {
      "id": "credential",
      "name": "硬编码凭据检测",
      "weight": 25,
      "rules": [
        {
          "id": "CRED-001",
          "name": "API Key泄露",
          "severity": "CRITICAL",
          "patterns": [
            "api[_-]?key\\s*[:=]\\s*['\"][a-zA-Z0-9_-]{20,}",
            "apikey\\s*[:=]\\s*['\"][a-zA-Z0-9_-]{20,}"
          ]
        },
        {
          "id": "CRED-002",
          "name": "AWS密钥泄露",
          "severity": "CRITICAL",
          "patterns": [
            "AKIA[0-9A-Z]{16}",
            "aws_secret_access_key",
            "AWS_ACCESS_KEY_ID"
          ]
        },
        {
          "id": "CRED-003",
          "name": "私钥泄露",
          "severity": "CRITICAL",
          "patterns": [
            "-----BEGIN\\s+(RSA\\s+)?PRIVATE\\s+KEY-----",
            "ssh-rsa\\s+AAAA"
          ]
        },
        {
          "id": "CRED-004",
          "name": "数据库凭据",
          "severity": "CRITICAL",
          "patterns": [
            "password\\s*[:=]\\s*['\"][^'\"]{8,}",
            "connection_string.*Password="
          ]
        },
        {
          "id": "CRED-005",
          "name": "Token泄露",
          "severity": "HIGH",
          "patterns": [
            "token\\s*[:=]\\s*['\"][a-zA-Z0-9_-]{20,}",
            "bearer\\s+[a-zA-Z0-9_-]+\\.[a-zA-Z0-9_-]+\\.[a-zA-Z0-_-]"
          ]
        },
        {
          "id": "CRED-006",
          "name": "OAuth凭据",
          "severity": "HIGH",
          "patterns": [
            "client_secret",
            "oauth\\s*[:=]",
            "refresh_token"
          ]
        },
        {
          "id": "CRED-007",
          "name": "连接字符串",
          "severity": "HIGH",
          "patterns": [
            "mongodb://",
            "redis://",
            "postgres://"
          ]
        },
        {
          "id": "CRED-008",
          "name": "Git Token",
          "severity": "HIGH",
          "patterns": [
            "ghp_[a-zA-Z0-9]{36}",
            "gho_[a-zA-Z0-9]{36}",
            "github_pat_"
          ]
        },
        {
          "id": "CRED-009",
          "name": "加密密钥",
          "severity": "HIGH",
          "patterns": [
            "encryption_key",
            "secret_key\\s*[:=]",
            "AES_KEY"
          ]
        },
        {
          "id": "CRED-010",
          "name": "JWT Secret",
          "severity": "HIGH",
          "patterns": [
            "jwt_secret",
            "JWT_SECRET",
            "HS256\\s*[:=]"
          ]
        },
        {
          "id": "CRED-011",
          "name": "Slack Token",
          "severity": "MEDIUM",
          "patterns": [
            "xox[baprs]-[0-9]{10,}"
          ]
        },
        {
          "id": "CRED-012",
          "name": "Facebook Token",
          "severity": "MEDIUM",
          "patterns": [
            "EAACEdEose0cBA[0-9A-Za-z]+"
          ]
        },
        {
          "id": "CRED-013",
          "name": "Google API Key",
          "severity": "MEDIUM",
          "patterns": [
            "AIza[0-9A-Za-z_-]{35}"
          ]
        },
        {
          "id": "CRED-014",
          "name": "Twilio API Key",
          "severity": "MEDIUM",
          "patterns": [
            "SK[a-f0-9]{32}"
          ]
        },
        {
          "id": "CRED-015",
          "name": "Stripe API Key",
          "severity": "HIGH",
          "patterns": [
            "sk_live_[0-9a-zA-Z]{24}"
          ]
        }
      ]
    },
    {
      "id": "data_leak",
      "name": "数据泄露检测",
      "weight": 15,
      "rules": [
        {
          "id": "LEAK-001",
          "name": "敏感文件访问",
          "severity": "HIGH",
          "patterns": [
            "open\\s*\\(\\s*['\"]/etc/passwd",
            "open\\s*\\(\\s*['\"]/etc/shadow",
            "~/.ssh/id_rsa"
          ]
        },
        {
          "id": "LEAK-002",
          "name": "日志泄露",
          "severity": "MEDIUM",
          "patterns": [
            "console\\.log.*password",
            "logging\\..*password",
            "print.*secret"
          ]
        },
        {
          "id": "LEAK-003",
          "name": "URL参数泄露",
          "severity": "MEDIUM",
          "patterns": [
            "\\?password=",
            "\\?token=",
            "\\?key=",
            "\\?secret="
          ]
        },
        {
          "id": "LEAK-004",
          "name": "Cookie泄露",
          "severity": "MEDIUM",
          "patterns": [
            "Set-Cookie.*password",
            "document\\.cookie.*token"
          ]
        },
        {
          "id": "LEAK-005",
          "name": "请求体泄露",
          "severity": "HIGH",
          "patterns": [
            "request\\.body.*password",
            "JSON\\.stringify.*credit_card"
          ]
        },
        {
          "id": "LEAK-006",
          "name": "响应泄露",
          "severity": "HIGH",
          "patterns": [
            "response\\.json.*password",
            "return.*token"
          ]
        },
        {
          "id": "LEAK-007",
          "name": "内存泄露",
          "severity": "MEDIUM",
          "patterns": [
            "gc\\.collect\\s*\\(\\s*\\)",
            "del\\s+"
          ]
        },
        {
          "id": "LEAK-008",
          "name": "备份文件",
          "severity": "MEDIUM",
          "patterns": [
            "\\.bak$",
            "\\.old$",
            "\\.swp$",
            "~"
          ]
        }
      ]
    },
    {
      "id": "insecure_exec",
      "name": "不安全执行检测",
      "weight": 20,
      "rules": [
        {
          "id": "EXEC-001",
          "name": "Shell注入",
          "severity": "CRITICAL",
          "patterns": [
            "system\\s*\\([^)]+\\$",
            "exec\\s*\\([^)]+\\$",
            "\\|\\s*\\$\\("
          ]
        },
        {
          "id": "EXEC-002",
          "name": "命令拼接",
          "severity": "CRITICAL",
          "patterns": [
            "\\+.*command",
            "f\\s*['\"].*\\$\\(",
            "format.*%s.*%"
          ]
        },
        {
          "id": "EXEC-003",
          "name": "模板注入命令",
          "severity": "CRITICAL",
          "patterns": [
            "\\{\\{.*\\$\\(",
            "<%.*import\\s+os",
            "#\\{.*system\\("
          ]
        },
        {
          "id": "EXEC-004",
          "name": "无过滤输入",
          "severity": "HIGH",
          "patterns": [
            "input\\s*\\(\\s*\\)",
            "raw_input"
          ]
        },
        {
          "id": "EXEC-005",
          "name": "危险函数指针",
          "severity": "HIGH",
          "patterns": [
            "Function\\s*\\(",
            "new\\s+Function",
            "setTimeout.*eval"
          ]
        },
        {
          "id": "EXEC-006",
          "name": "动态代码生成",
          "severity": "HIGH",
          "patterns": [
            "createFunction",
            "lambda\\s+.*os\\.",
            "types\\.FunctionType"
          ]
        },
        {
          "id": "EXEC-007",
          "name": "脚本执行",
          "severity": "HIGH",
          "patterns": [
            "script\\.src\\s*=",
            "eval\\s*\\(\\s*script",
            "innerHTML\\s*="
          ]
        },
        {
          "id": "EXEC-008",
          "name": "进程创建",
          "severity": "MEDIUM",
          "patterns": [
            "ProcessBuilder",
            "Runtime\\.getRuntime\\.exec",
            "child_process\\.execSync"
          ]
        },
        {
          "id": "EXEC-009",
          "name": "危险协议",
          "severity": "HIGH",
          "patterns": [
            "javascript:",
            "vbscript:",
            "data:text/html"
          ]
        }
      ]
    },
    {
      "id": "network_attack",
      "name": "网络攻击检测",
      "weight": 15,
      "rules": [
        {
          "id": "NET-001",
          "name": "SQL注入",
          "severity": "CRITICAL",
          "patterns": [
            "['\"]\\s*(OR|AND)\\s+['\"]\\s*['\"]\\s*=",
            "union\\s+select",
            "execute\\s*\\(\\s*['\"]\\s*insert"
          ]
        },
        {
          "id": "NET-002",
          "name": "XSS攻击",
          "severity": "HIGH",
          "patterns": [
            "<script",
            "javascript:",
            "onerror\\s*=",
            "onload\\s*="
          ]
        },
        {
          "id": "NET-003",
          "name": "CSRF攻击",
          "severity": "HIGH",
          "patterns": [
            "csrf_token",
            "xsrf_token"
          ]
        },
        {
          "id": "NET-004",
          "name": "SSRF攻击",
          "severity": "CRITICAL",
          "patterns": [
            "requests\\.get.*url",
            "urllib\\.request.*urlopen.*user"
          ]
        },
        {
          "id": "NET-005",
          "name": "XXE攻击",
          "severity": "CRITICAL",
          "patterns": [
            "DOCTYPE\\s+html",
            "Entity\\s+",
            "SYSTEM\\s+['\"]file:"
          ]
        },
        {
          "id": "NET-006",
          "name": "路径遍历",
          "severity": "HIGH",
          "patterns": [
            "\\.\\./",
            "\\.\\.\\\\",
            "%2e%2e"
          ]
        },
        {
          "id": "NET-007",
          "name": "命令注入",
          "severity": "CRITICAL",
          "patterns": [
            "&&\\s+\\w+",
            "\\|\\|\\s+\\w+",
            ";\\s+\\w+"
          ]
        }
      ]
    },
    {
      "id": "file_ops",
      "name": "文件操作检测",
      "weight": 10,
      "rules": [
        {
          "id": "FILE-001",
          "name": "任意文件读取",
          "severity": "HIGH",
          "patterns": [
            "open\\s*\\([^)]+mode\\s*=\\s*['\"]r",
            "readfile\\s*\\([^)]+\\)"
          ]
        },
        {
          "id": "FILE-002",
          "name": "任意文件写入",
          "severity": "CRITICAL",
          "patterns": [
            "open\\s*\\([^)]+mode\\s*=\\s*['\"]w",
            "file_put_contents"
          ]
        },
        {
          "id": "FILE-003",
          "name": "文件上传",
          "severity": "HIGH",
          "patterns": [
            "move_uploaded_file",
            "multipart/form-data",
            "enctype.*file"
          ]
        },
        {
          "id": "FILE-004",
          "name": "文件删除",
          "severity": "MEDIUM",
          "patterns": [
            "unlink\\s*\\(",
            "rmdir\\s*\\(",
            "remove\\s*\\("
          ]
        },
        {
          "id": "FILE-005",
          "name": "目录遍历",
          "severity": "HIGH",
          "patterns": [
            "readdir\\s*\\(",
            "scandir\\s*\\(",
            "listdir\\s*\\("
          ]
        },
        {
          "id": "FILE-006",
          "name": "文件包含",
          "severity": "HIGH",
          "patterns": [
            "include\\s*\\([^)]+\\$",
            "require\\s*\\([^)]+\\$",
            "__import__\\s*\\(['\"]os"
          ]
        },
        {
          "id": "FILE-007",
          "name": "敏感文件修改",
          "severity": "HIGH",
          "patterns": [
            "chmod\\s*\\([^)]+0",
            "chown\\s*\\(",
            "umask\\s*\\("
          ]
        },
        {
          "id": "FILE-008",
          "name": "符号链接",
          "severity": "MEDIUM",
          "patterns": [
            "symlink\\s*\\(",
            "link\\s*\\(",
            "readlink"
          ]
        }
      ]
    },
    {
      "id": "obfuscation",
      "name": "代码混淆检测",
      "weight": 10,
      "rules": [
        {
          "id": "OBF-001",
          "name": "字符串混淆",
          "severity": "MEDIUM",
          "patterns": [
            "\\\\x[0-9a-f]{2}",
            "\\\\u[0-9a-f]{4}",
            "String\\.fromCharCode"
          ]
        },
        {
          "id": "OBF-002",
          "name": "变量名混淆",
          "severity": "MEDIUM",
          "patterns": [
            "var\\s+[0oO]{2,}",
            "let\\s+[l1i]{2,}",
            "_0x[0-9a-f]{4}"
          ]
        },
        {
          "id": "OBF-003",
          "name": "代码压缩",
          "severity": "LOW",
          "patterns": [
            "^function\\(\\)\\{[^}]{200,}\\}",
            "eval\\s*\\(\\s*function\\s*\\("
          ]
        },
        {
          "id": "OBF-004",
          "name": "JS混淆",
          "severity": "MEDIUM",
          "patterns": [
            "window\\[['\\\"][a-zA-Z]+['\\\"]\\]",
            "\\$_\\[",
            "\\$_GET\\s*\\("
          ]
        },
        {
          "id": "OBF-005",
          "name": "Hex编码",
          "severity": "MEDIUM",
          "patterns": [
            "0x[0-9a-f]{2,}",
            "chr\\s*\\(\\s*0x"
          ]
        },
        {
          "id": "OBF-006",
          "name": "Rot13编码",
          "severity": "LOW",
          "patterns": [
            "str_rot13"
          ]
        },
        {
          "id": "OBF-007",
          "name": "多层编码",
          "severity": "HIGH",
          "patterns": [
            "base64.*zlib",
            "gzip.*base64",
            "encode.*decode.*encode"
          ]
        },
        {
          "id": "OBF-008",
          "name": "动态代码执行",
          "severity": "HIGH",
          "patterns": [
            "setInterval\\s*\\(\\s*/",
            "setTimeout\\s*\\(\\s*/",
            "eval.*atob"
          ]
        }
      ]
    },
    {
      "id": "dependency",
      "name": "依赖风险检测",
      "weight": 10,
      "rules": [
        {
          "id": "DEPS-001",
          "name": "已知漏洞库",
          "severity": "HIGH",
          "patterns": [
            "pyyaml\\s*(<\\s*5\\.3|==.*\\.3\\.)",
            "requests\\s*<\\s*2\\.20",
            "flask\\s*<\\s*1\\.0"
          ]
        },
        {
          "id": "DEPS-002",
          "name": "危险依赖",
          "severity": "HIGH",
          "patterns": [
            "pickle",
            "yaml",
            "eval-parser"
          ]
        },
        {
          "id": "DEPS-003",
          "name": "未维护依赖",
          "severity": "MEDIUM",
          "patterns": [
            "last_release.*\\d{4}",
            "deprecated.*true"
          ]
        },
        {
          "id": "DEPS-004",
          "name": "弱加密库",
          "severity": "MEDIUM",
          "patterns": [
            "hashlib\\.md5",
            "hashlib\\.sha1",
            "Crypto\\.Cipher\\.DES"
          ]
        },
        {
          "id": "DEPS-005",
          "name": "不安全的HTTP",
          "severity": "MEDIUM",
          "patterns": [
            "http://[^/]+(?!localhost|127\\.0\\.0\\.1)",
            "urllib3.*verify\\s*=\\s*False"
          ]
        },
        {
          "id": "DEPS-006",
          "name": "调试依赖",
          "severity": "LOW",
          "patterns": [
            "debug.*true",
            "devDependencies",
            "webpack-dev-server"
          ]
        }
      ]
    },
    {
      "id": "phishing",
      "name": "钓鱼/诱导检测",
      "weight": 30,
      "rules": [
        {
          "id": "PHISH-001",
          "name": "隐藏curl命令",
          "severity": "CRITICAL",
          "patterns": [
            "curl.*\\|\\s*sh",
            "curl.*\\|\\s*bash",
            "Invoke-Expression.*curl"
          ],
          "description": "检测钓鱼站点的隐藏下载命令"
        },
        {
          "id": "PHISH-002",
          "name": "z-index全屏覆盖",
          "severity": "HIGH",
          "patterns": [
            "z-index:\\s*2147483647",
            "zIndex:\\s*2147483647",
            "position:\\s*fixed.*top:\\s*0"
          ],
          "description": "检测全屏覆盖伪装"
        },
        {
          "id": "PHISH-003",
          "name": "页面清空注入",
          "severity": "HIGH",
          "patterns": [
            "document\\.body\\.innerHTML\\s*=\\s*['\"]['\"]",
            "innerHTML\\s*=\\s*['\"]['\"]",
            "body\\.innerHTML\\s*=\\s*['\"]['\"]"
          ],
          "description": "检测页面内容替换"
        },
        {
          "id": "PHISH-004",
          "name": "可疑域名",
          "severity": "HIGH",
          "patterns": [
            "\\.pages\\.dev",
            "\\.vercel\\.app.*\\d{4,}",
            "\\.herokuapp\\.com",
            "\\.glitch\\.me"
          ],
          "description": "检测可疑免费托管域名"
        },
        {
          "id": "PHISH-005",
          "name": "伪装登录框",
          "severity": "HIGH",
          "patterns": [
            "type\\s*=\\s*['\"]password['\"]",
            "<input.*password",
            "ng-model.*password"
          ],
          "description": "检测伪造的登录表单"
        },
        {
          "id": "PHISH-006",
          "name": "平台检测按钮",
          "severity": "MEDIUM",
          "patterns": [
            "mac.*download.*windows",
            "platform.*mac.*windows",
            "navigator\\.platform"
          ],
          "description": "检测针对不同平台的不同诱导内容"
        },
        {
          "id": "PHISH-007",
          "name": "隐藏iframe",
          "severity": "HIGH",
          "patterns": [
            "<iframe[^>]*display:\\s*none",
            "<iframe[^>]*visibility:\\s*hidden",
            "iframe.*width\\s*=\\s*0"
          ],
          "description": "检测隐藏的iframe加载"
        },
        {
          "id": "PHISH-008",
          "name": "反调试机制",
          "severity": "MEDIUM",
          "patterns": [
            "debugger",
            "devtools.*open",
            "console\\.disable"
          ],
          "description": "检测反分析行为"
        },
        {
          "id": "PHISH-009",
          "name": "诱导点击",
          "severity": "HIGH",
          "patterns": [
            "click\\s*.*download",
            "onclick.*install",
            "button.*mac.*windows"
          ],
          "description": "检测诱导性点击元素"
        },
        {
          "id": "PHISH-010",
          "name": "URL重定向",
          "severity": "MEDIUM",
          "patterns": [
            "window\\.location\\s*=\\s*['\"][^'\"]+",
            "location\\.href\\s*=",
            "meta\\s+http-equiv\\s*=\\s*refresh"
          ],
          "description": "检测隐藏的重定向"
        }
      ]
    },
    {
