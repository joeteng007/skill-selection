{
  "schema_version": "1.0",
  "skill_name": "pixcake",
  "public_entry": true,
  "package_layout": "single-skill-with-references",
  "min_client_version": "9.0.0",
  "supported_platforms": [
    "darwin",
    "win32"
  ],
  "runtime": {
    "primary_command": "node ./scripts/pixcake_bridge.js",
    "flow": [
      "doctor",
      "list",
      "call"
    ],
    "env_overrides": [
      "PIXCAKE_BRIDGE_CMD",
      "PIXCAKE_SOCKET_PATH",
      "PIXCAKE_SKILLS_CONFIG"
    ],
    "config_sources": [
      "~/.openclaw/skills/pixcake-skills/config.local.json",
      "./config.local.json"
    ]
  },
  "domains": {
    "projects": {
      "reference": "./references/projects.md",
      "required_tools": [
        "get_project_list",
        "create_projects",
        "import_images_to_projects",
        "get_project_images"
      ]
    },
    "retouch": {
      "reference": "./references/retouch.md",
      "required_tools": [
        "get_preset_suit_list",
        "apply_preset_suit"
      ]
    },
    "export": {
      "reference": "./references/export.md",
      "required_tools": [
        "export_images"
      ]
    }
  },
  "scope": {
    "supported": [
      "project_management",
      "preset_retouch",
      "export"
    ],
    "unsupported": [
      "camera",
      "ai_culling",
      "ai_retouch",
      "ai_color_match",
      "filter",
      "background_replace",
      "bystander_removal",
      "smart_crop"
    ]
  },
  "path_resolution": "Resolve local file paths with the agent's own shell or command tools before PixCake calls.",
  "mismatch_policy": "If doctor, list, or call signals incompatibility, stop probing, recommend upgrading PixCake to 9.0.0 or newer, and suggest support if the issue remains."
}
